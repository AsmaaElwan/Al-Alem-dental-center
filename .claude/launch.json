{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "royal",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path'),port=process.env.PORT||3456;h.createServer((q,r)=>{let f=p.join('/Users/asmaaelwan/Desktop/royal',q.url==='/'?'/index.html':q.url.split('?')[0]);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end();}else{const m={'html':'text/html','css':'text/css','js':'application/javascript','jpg':'image/jpeg','png':'image/png','mp4':'video/mp4','woff2':'font/woff2'};r.writeHead(200,{'Content-Type':m[f.split('.').pop()]||'text/plain'});r.end(d);}});}).listen(port,()=>console.log('ready on '+port));"],
      "port": 3456,
      "autoPort": true
    }
  ]
}
